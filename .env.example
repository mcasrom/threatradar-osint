# ThreatRadar OSINT — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git

# App
NODE_ENV=development
PORT=3000
JWT_SECRET=cambia-esto-en-produccion

# Dev user (crear con: npm run seed:dev o via /api/auth/register)
# email: dev@threatradar.local / plan: pro

# APIs OSINT
GEMINI_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
HUNTER_API_KEY=
GREYNOISE_API_KEY=
IPINFO_API_KEY=
SECURITYTRAILS_API_KEY=

# Stripe (producción)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SMTP_FROM=no-reply@threatradar.com
