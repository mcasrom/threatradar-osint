# ==========================================
# THREATRADAR OSINT - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Core Application ---
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# --- AI Engine (Google Gemini) ---
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Payment Processing (Stripe) ---
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# --- Email Dispatch (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ThreatRadar SOC <your_email@domain.com>"

# --- Threat Intelligence APIs ---
# Shodan: https://developer.shodan.io/
SHODAN_API_KEY=

# AbuseIPDB: https://www.abuseipdb.com/api.html
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# HaveIBeenPwned: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# --- Optional OSINT APIs ---
# SecurityTrails: https://securitytrails.com/corp/api
SECURITYTRAILS_API_KEY=

# GreyNoise: https://www.greynoise.io/
GREYNOISE_API_KEY=

# Hunter.io: https://hunter.io/api
HUNTER_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/
ALIENVAULT_OTX_KEY=

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
